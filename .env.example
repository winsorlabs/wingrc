# Copy to .env and adjust. Never commit real secrets.
WINGRC_DATABASE_URL=postgresql+psycopg://wingrc:wingrc@localhost:5432/wingrc
WINGRC_ENVIRONMENT=development

# AI provider abstraction (not used by the scope module yet):
#   none | anthropic | azure_openai | local
WINGRC_AI_PROVIDER=none
# ANTHROPIC_API_KEY=

# S3-compatible object storage (MinIO in dev).
# storage_endpoint is the internal Docker endpoint the backend uses to reach MinIO.
# storage_public_endpoint is the LAN/public address browsers use to reach MinIO —
# required when the backend runs in Docker and the browser runs on a different host.
# Without this, presigned URLs contain the internal 'minio' hostname (ERR_NAME_NOT_RESOLVED).
# WINGRC_STORAGE_ENDPOINT=http://minio:9000
# WINGRC_STORAGE_PUBLIC_ENDPOINT=http://10.10.24.35:9000
# WINGRC_STORAGE_ACCESS_KEY=wingrc
# WINGRC_STORAGE_SECRET_KEY=wingrc-dev-secret
# WINGRC_STORAGE_BUCKET=evidence

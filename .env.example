# Copy to .env and adjust. Never commit real secrets.
WINGRC_DATABASE_URL=postgresql+psycopg://wingrc:wingrc@localhost:5432/wingrc

# "development" or "production". This is the ONLY thing that flips the
# session cookie's Secure flag on (see backend/app/auth.py) — there is no
# separate cookie-secure env var. Set to "production" for ANY deployment
# served over HTTPS/a real domain, including self-hosted single-tenant
# instances; leave "development" only for local/LAN work without TLS.
WINGRC_ENVIRONMENT=development

# AI provider abstraction (not used by the scope module yet):
#   none | anthropic | azure_openai | local
WINGRC_AI_PROVIDER=none
# ANTHROPIC_API_KEY=

# S3-compatible object storage (MinIO in dev).
# storage_endpoint is the internal Docker endpoint the backend uses to reach MinIO.
# storage_public_endpoint is the address browsers use to reach MinIO —
# required when the backend runs in Docker and the browser runs on a different host.
# Without this, presigned URLs contain the internal 'minio' hostname (ERR_NAME_NOT_RESOLVED).
#
# Behind the nginx reverse proxy (see docs/deployment.md), this must be the
# dedicated storage subdomain over HTTPS, e.g. https://storage.YOUR_HOSTNAME —
# NOT a path under the main app hostname (MinIO's bucket routing needs the
# unprefixed path, so a path prefix breaks presigned-URL signature
# validation; see deploy/nginx/nginx.conf for the full explanation).
# For LAN-only dev without the proxy, a bare LAN IP:9000 still works, e.g.
# http://10.10.24.35:9000.
# WINGRC_STORAGE_ENDPOINT=http://minio:9000
# WINGRC_STORAGE_PUBLIC_ENDPOINT=https://storage.YOUR_HOSTNAME
# WINGRC_STORAGE_ACCESS_KEY=wingrc
# WINGRC_STORAGE_SECRET_KEY=wingrc-dev-secret
# WINGRC_STORAGE_BUCKET=evidence

# MinIO's own public URL (set only when nginx fronts it in production) — see
# docker-compose.yml comment on the minio service.
# MINIO_SERVER_URL=https://storage.YOUR_HOSTNAME
